@startuml 
left to right direction

scale 1000 width
scale 1000 height
skinparam nodesep 150
skinparam ranksep 80

skinparam state {
  BackgroundColor LightBlue
  BorderColor DarkBlue
  FontSize 50
  ArrowColor DarkSlateGray
}
skinparam ArrowFontSize 35
skinparam backgroundColor White
skinparam shadowing false

title Ball & Plate — PID Simulation : Ball State Machine

[*] --> IDLE

state IDLE {
  [*] --> waiting
  waiting : No ball exists
}

state DRAGGING {
  [*] --> holding
  holding : Ball follows cursor
  holding : vx = vy = vz = 0
}

state AIRBORNE {
  [*] --> falling
  falling : Gravity applied
  falling : ax, ay from plate tilt
}

state BOUNCING {
  [*] --> rebound
  rebound : vz = vz × RESTITUTION
  rebound : vx, vy × BOUNCE_FRICTION
}

state ON_PLATE {
  [*] --> balancing
  balancing : PID active (full weight = 1.0)
  balancing : Rolling friction applied
}

state ORBIT_TRACKING {
  [*] --> chasing
  chasing : Setpoint orbits in circle
  chasing : PID chases moving target
}

state PUSH_MODE {
  [*] --> push_idle
  push_idle : PushAimer active
  push_idle : LMB click places ball if none exists
  --
  [*] --> aiming
  aiming : Drag arrow drawn on screen
  aiming : start_sx/sy locked to ball position
  aiming : end_sx/sy follows cursor
  --
  [*] --> impulse_applied
  impulse_applied : vx += wxd/ln × push_power
  impulse_applied : vy += wyd/ln × push_power
  impulse_applied : vz = 0, on_plate = True
  impulse_applied : PID integral × 0.35 (soft reset)
}

state DEAD {
  [*] --> lost
  lost : drops++
  lost : ball = None
}

IDLE --> DRAGGING       : LMB click\n(normal mode)
IDLE --> AIRBORNE       : [T] Throw mode\nLMB release

DRAGGING -> DRAGGING   : Mouse move\n(update XY and Z)
DRAGGING --> AIRBORNE   : LMB release\n(vx=vy=vz=0)

AIRBORNE --> BOUNCING   : z ≤ plate_z AND\nimpact_speed ≥ MIN_BOUNCE
AIRBORNE --> ON_PLATE   : z ≤ plate_z AND\nimpact_speed < MIN_BOUNCE
AIRBORNE --> DEAD       : z < -800\n(fell off world)

BOUNCING --> AIRBORNE   : vz > 0\n(ball lifts off again)
BOUNCING --> ON_PLATE   : impact_speed < MIN_BOUNCE\n(energy dissipated)

ON_PLATE --> AIRBORNE   : vz > threshold\n(re-lift)
ON_PLATE --> DEAD       : dist > PLATE_SIZE\n(rolled off edge)
ON_PLATE --> ORBIT_TRACKING : [O] key pressed
ON_PLATE --> PUSH_MODE  : [U] key pressed

ORBIT_TRACKING --> ON_PLATE : [O] key toggled off
ORBIT_TRACKING --> DEAD     : dist > PLATE_SIZE
ORBIT_TRACKING --> PUSH_MODE : [U] key pressed

PUSH_MODE --> ON_PLATE  : [U] key toggled off\n(pusher.active = False)
PUSH_MODE --> DEAD      : dist > PLATE_SIZE\n(ball rolls off edge)

' ── Push Mode internal flow ───────────────
PUSH_MODE : push_idle --> aiming     : LMB press on sim area\n(ball exists)
PUSH_MODE : aiming --> impulse_applied : LMB release\n(drag length > 4 px)
PUSH_MODE : impulse_applied --> push_idle : impulse delivered\naimer reset

DEAD --> IDLE           : Auto-reset\n(ball = None)

' ==========================================
' 4. GLOBAL RESET COMMANDS
' ==========================================
DRAGGING       -[dashed]-> IDLE : [R] Reset
AIRBORNE       -[dashed]-> IDLE : [R] Reset
ON_PLATE       -[dashed]-> IDLE : [R] Reset
BOUNCING       -[dashed]-> IDLE : [R] Reset
ORBIT_TRACKING -[dashed]-> IDLE : [R] Reset
PUSH_MODE      -[dashed]-> IDLE : [R] Reset
DEAD           -[dashed]-> IDLE : [R] Reset

@enduml
