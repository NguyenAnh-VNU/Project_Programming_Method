@startuml
left to right direction

skinparam {
    nodesep 150
    ranksep 150
    shadowing false
    DefaultFontName "Arial"
    
    state {
        BackgroundColor LightBlue
        BorderColor DarkBlue
        FontSize 45
        FontStyle bold
        AttributeFontSize 60
        AttributeFontStyle plain
    }
    
    arrow {
        Color DarkSlateGray
        FontSize 50
        FontStyle bold
    }
    
    title {
        FontSize 60
    }
}

title Ball & Plate Simulation : Ball State Machine

[*] --> IDLE

state IDLE {
    [*] --> waiting
    waiting : No ball exists
}

state DRAGGING {
    [*] --> holding
    holding : Ball follows cursor
    holding : vx = vy = vz = 0
}

state AIRBORNE {
    [*] --> falling
    falling : Gravity applied
    falling : ax, ay from plate tilt
}

state BOUNCING {
    [*] --> rebound
    rebound : vz = vz × RESTITUTION
    rebound : vx, vy × BOUNCE_FRICTION
}

state ON_PLATE {
    [*] --> balancing
    balancing : PID active (Weight=1.0)
    balancing : Rolling friction applied
}

state ORBIT_TRACKING {
    [*] --> chasing
    chasing : Setpoint orbits in circle
    chasing : PID chases moving target
}

state PUSH_MODE {
    [*] --> push_idle
    push_idle : PushAimer active
    --
    [*] --> aiming
    aiming : Drag arrow drawn
    --
    [*] --> APPLYING_IMPULSE
    APPLYING_IMPULSE : vx, vy increased
    APPLYING_IMPULSE : PID soft reset
}

state DEAD {
    [*] --> lost
    lost : drops++
    lost : ball = None
}

state RESET_HUB <<choice>>

DRAGGING       -[dashed]-> RESET_HUB
AIRBORNE       -[dashed]-> RESET_HUB
ON_PLATE       -[dashed]-> RESET_HUB
BOUNCING       -[dashed]-> RESET_HUB
ORBIT_TRACKING -[dashed]-> RESET_HUB
PUSH_MODE      -[dashed]-> RESET_HUB
DEAD           -[dashed]-> RESET_HUB
RESET_HUB -up-> IDLE : [R] Reset

IDLE -[hidden]right-> DRAGGING
IDLE -down-> DRAGGING : LMB click\n(normal mode)
IDLE -right-> AIRBORNE : [U] Push mode\nLMB release

DRAGGING -> DRAGGING : Mouse move\n(update XY and Z)
DRAGGING -down-> AIRBORNE : LMB release

AIRBORNE -right-> BOUNCING : z ≤ plate_z AND\nimpact_speed ≥ MIN_BOUNCE
AIRBORNE -right-> ON_PLATE : z ≤ plate_z AND\nimpact_speed < MIN_BOUNCE
AIRBORNE -down-> DEAD : z < -800\n(fell off world)

BOUNCING -up-> AIRBORNE : vz > 0
BOUNCING -right-> ON_PLATE : impact_speed < MIN_BOUNCE

ON_PLATE -up-> AIRBORNE : vz > threshold
ON_PLATE -down-> DEAD : dist > PLATE_SIZE
ON_PLATE -right-> ORBIT_TRACKING : [O] key pressed
ON_PLATE -down-> PUSH_MODE : [U] key pressed

ORBIT_TRACKING -left-> ON_PLATE : [O] key toggled off
ORBIT_TRACKING -down-> DEAD : dist > PLATE_SIZE
ORBIT_TRACKING -right-> PUSH_MODE : [U] key pressed

PUSH_MODE -left-> ON_PLATE : [U] key toggled off
PUSH_MODE -down-> DEAD : dist > PLATE_SIZE

PUSH_MODE : push_idle --> aiming : LMB press
PUSH_MODE : aiming --> APPLYING_IMPULSE : LMB release
PUSH_MODE : APPLYING_IMPULSE --> push_idle : impulse delivered

DEAD -up-> IDLE : Auto-reset

@enduml